# WMS2 Configuration
# Copy to .env and fill in real values. .env is gitignored.

# Database (required)
WMS2_DATABASE_URL=postgresql+asyncpg://wms2:CHANGEME@localhost:5432/wms2

# User identity (required for test/global pool mode)
WMS2_ACCOUNTING_GROUP_USER=CHANGEME
WMS2_TEST_LFN_USER=CHANGEME.wms2
WMS2_RUCIO_TEST_ACCOUNT=CHANGEME

# HTCondor
WMS2_CONDOR_HOST=localhost:9618
WMS2_EXTRA_COLLECTORS=
WMS2_REMOTE_SCHEDD=
WMS2_SEC_TOKEN_DIRECTORY=

# Remote schedd spool access
WMS2_SPOOL_MOUNT=
WMS2_REMOTE_SPOOL_PREFIX=

# Service
WMS2_DB_POOL_SIZE=10
WMS2_LIFECYCLE_CYCLE_INTERVAL=60
WMS2_MAX_ACTIVE_DAGS=300
WMS2_API_PREFIX=/api/v1
WMS2_LOG_LEVEL=INFO
WMS2_DEBUG=false
